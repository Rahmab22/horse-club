<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
		<link rel="stylesheet" href="{{ asset('css/style.css') }}">
	{% block stylesheets %}
		{% endblock %}

		{% block javascripts %}
		{% endblock %}
	</head>
	<body>
		{% block header %}

			<header>

				<nav class="navbg navbar navbar-expand-lg ">
					<div class="container-fluid">
						<a class="navbar-brand" href="index.html">Horse Club</a>
						<div class="collapse navbar-collapse" id="navbarTogglerDemo01">
							<img src="images/HORSE CLUB.png" class="img-thumbnail" alt="Logo" width="60" ms-3>
							<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
								<span class="navbar-toggler-icon"></span>
							</button>
							<div class="collapse navbar-collapse" id="navbarSupportedContent">
								<ul
									class="nav justify-content-center">
									<!-- Utilisation de ms-auto pour aligner à droite -->
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/home">Accueil</a>
									</li>
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/equipe">Notre Equipe</a>
									</li>
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/cours">Cours</a>
									</li>
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/penssion">Pension</a>
									</li>
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/boutique">Boutique</a>
									</li>
									<li class="nav-item">
										<a class="nav-link active" aria-current="page" href="/contact">Contact</a>
									</li>
								</ul>
							</div>
						</div>
						<div class="cart-icon position-relative">
							<img src="images/panier.png" width="30" alt="Panier">
							<span id="cart-count" class="cart-count">0</span>
						</div>
					</div>
				</nav>
			</header>


		{% endblock %}

		{% block body %}{% endblock %}
		{% block footer %}

			<footer class="footer-light-theme py-5 mt-5">
				<div class="container">
					<div class="row">
						<div class="col-md-4 mb-4 mb-md-0 text-white">
							<h5 class="text-uppercase mb-4 border-bottom pb-2 text-white ">Infos</h5>
							<p class="small text-white">
								HorsClub est votre espace dédié à la passion de l’équitation. Notre mission
								                                :
								                                accompagner
								                                cavaliers et chevaux dans la découverte et le partage de ce lien unique. 
								                                Que
								                                vous
								                                soyez
								                                débutant ou confirmé, à la recherche d’actualités, de conseils pratiques, de
								                                formations ou d’une
								                                communauté d’entraide, HorsClub est là pour vous.  Rejoignez-nous et vivez
								                                pleinement chaque
								                                galop, chaque saut… ensemble.
							</p>
						</div>

						<div class="col-md-4 mb-4 mb-md-0 text-white">
							<h5 class="text-uppercase mb-4 border-bottom pb-2">Menu</h5>
							<ul class="list-unstyled">
								<li class="mb-2">
									<a href="#" class="text-white">Accueil</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Notre Equipe</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Cours</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Pension</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Boutique</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Contact</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Conditions Générales</a>
								</li>
								<li class="mb-2">
									<a href="#" class="text-white">Politique de
										                                        Confidentialité</a>
								</li>
							</ul>
						</div>

						<div class="col-md-4 text-white">
							<h5 class="text-uppercase mb-4 border-bottom pb-2 text-white">Contact</h5>
							<p class="small text-white">Abonnez-vous à notre newsletter pour recevoir les
								                                dernières
								                                actualités
								                                et
								                                offres.</p>
							<form>
								<div class="input-group mb-3">
									<input type="email" class="form-control" placeholder="Votre email" aria-label="Votre email" aria-describedby="button-addon2">
									<button class="btn btn-primary text-black" type="button" id="button-addon2">S'abonner</button>
								</div>
							</form>
							<div class="d-flex justify-content-center justify-content-md-start mt-4">
								<a href="#" class="text-white me-3">
									<i class="bi bi-facebook fs-4"></i>
								</a>
								<a href="#" class="text-white me-3">
									<i class="bi bi-twitter fs-4"></i>
								</a>
								<a href="#" class="text-white me-3">
									<i class="bi bi-instagram fs-4"></i>
								</a>
								<a href="#" class="text-white">
									<i class="bi bi-linkedin fs-4"></i>
								</a>
							</div>
						</div>
					</div>
					<hr class="mt-5 mb-4 border-secondary text-white">
					<div class="text-center">
						<p class="mb-0 small">&copy; 2025 Horse Club - Tous droits réservés</p>
					</div>
				</div>
			</footer>


		{% endblock %}


		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
	</body>
</html>

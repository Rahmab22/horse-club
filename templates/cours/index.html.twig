{% extends 'base.html.twig' %}

{% block title %}Hello CoursController!
{% endblock %}

{% block body %}

	<body
		class="image-cours">

		<!--PRESENTATION DU DEBUT DU SITE -->
		<div class="container mt-5 py-5 text-center">
			<h1 class="mb-5 display-5 fw-bold text-black">NOS TARIFS</h1>
			<div class="row justify-content-center g-4">
				<div class="text-start">
					<div class="text-start"></div>
					<p class="fs-5 text-black">
						Bienvenue au Horse Club, l’école d’équitation où chacun trouve sa place.
												                    Que vous soyez petit cavalier en herbe ou passionné confirmé, nos cours sont
												                    conçus, pour progresser à votre rythme, dans un cadre bienveillant et sécurisé.
												                    Baby poney, cours collectifs ou séances personnalisées : chaque moment passé au clubs est une
												                    aenture à cheval, encadrée par des professionnels passionnés.
					</p>
				</div>
			</div>

			<!--FIN DE PRESENTATION DU SITE-->


			<!-- TARIF N°1-->
			<section class="bg-section">

				<div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
					<div class="col">
						<div class="card glass-card p-3 h-100">
							<img src="images/game_16462408.png" alt="Logo" class="logo logo-carte mx-auto mb-3">
							<h5 class="card-tittle">Cours Collectifs adulte</h5>
							<ul class="liste-tarifs">
								<li>Groupes de niveau (débutant à galop 7)</li>
								<li>Duré : 1h</li>
								<li>Maximum 5 cavaliers par cours</li>
								<li>Tarifs à la séances: 25 €</li>
								<li>Carte de 10 séances: 220€</li>
								<li>Abonnement trimestriel:190€/mois</li>
							</ul>
						</div>
					</div>

					<!--TARIF 2-->

					<div class="col">
						<div class="card glass-card p-3 h-100">
							<img src="images/horse_101694.png" alt="Logo" class="logo logo-carte mx-auto mb-3">
							<h5 class="card-tittle">Cours Particuliers adulte</h5>
							<ul class="liste-tarifs">
								<li>Travail sur mesure (préparation au galops, remise en confiance, dressage, obstacle ...)
								</li>
								<li>Duré : 1h</li>
								<li>Uniquement sur rendez-vous</li>
								<li>Tarif à la séance : 45 €</li>
							</ul>
						</div>
					</div>

					<!--TARIF 3-->

					<div class="col">
						<div class="card glass-card p-3 h-100">
							<img src="images/horse_101694.png" alt="Logo" class="logo logo-carte mx-auto mb-3">
							<h5 class="card-tittle">Cours particulier enfant</h5>
							<ul class="liste-tarifs">
								<li>Apprentissage des soins, du pansage et de l'équipement (seller et brider)</li>
								<li>Duré : 30 min</li>
								<li>Tarif à la séance : 30 €</li>
							</ul>
						</div>
					</div>
				</div>


				<!--TARIF 4-->

				<!--  <div class="row justify-content-center g-4 h-100"> -->
				<div class="col">
					<div class="card glass-card p-3 h-100">
						<img src="images/horse_882157.png" alt="Logo" class="logo logo-carte mx-auto mb-3">
						<h5 class="card-tittle">Baby poney</h5>
						<ul class="liste-tarifs">
							<li>Apprentissage des soins, du pansage et de l'équipement (seller et brider).</li>
							<li>Duré : 30 min</li>
							<li>Tarif à la séance : 15 €</li>
							<li>Carte de 10 séances: 130 €</li>
							<li>Abonnement trimestriel : 110€/mois</li>
						</ul>
					</div>
				</div>

				<!--TARIF 5-->

				<div class="col">
					<div class="card glass-card p-3 h-100">
						<img src="images/travel_16431624.png" alt="Logo" class="logo logo-carte mx-auto mb-3">
						<h5 class="card-tittle">Cours collectifs enfants</h5>
						<ul class="liste-tarifs">
							<li>Apprentissage des soins, du pansage et de l'équipement (seller et brider)</li>
							<li>Duré : 1h</li>
							<li>Cours individuels</li>
							<li>Tarifs à la séances: 22€</li>
							<li>Carte de 10 séances: 200 €</li>
							<li>Abonnement trimestriel : 170€/mois</li>
						</ul>
					</div>
				</div>
			</div>


		

	
</body>
{% endblock %}
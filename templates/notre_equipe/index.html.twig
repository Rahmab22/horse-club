									<!-- Button trigger modal -->
									<button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#exampleModal" data-nom="Ollivier" data-titre="Directeur" data-description="Directeur du centre équestre et instructeur diplômé d'Etat. Passionné des chevaux depuis tout-peti, il a fait ke choix de bâtir son propre centre équestre, afin qu'il puisse travailler de sa passion.">

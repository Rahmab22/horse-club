{% extends 'base.html.twig' %}

{% block title %}Hello NotreEquipeController!
{% endblock %}

{% block body %}

	<body
		class="image-equipe">
	

			<!--PRESENTATION DE LEQUIPE -->
			<section class="container mt-5 py-5 text-center">
				<h1 class="mb-5 display-5 fw-bold text-black">Rencontrez notre Equipe</h1>
				<div class="row justify-content-center g-4">
					<div class="text-start">
						<div class="text-start"></div>
						<p class="fs-5 text-black">
							Les cours d'équitations sont encadrés par des monitrices et
							                    moniteurs diplômés. Les cours peuvent être enseignés au enfant à partir de 3 ans et aux adultes de
							                    tout niveaux.
						</p>
					</div>
				</div>

				<!--MODAL-->
				<!--OLIVIER-->
				<section class="container mt-5 py-5 text-center">
					<div class="row justify-content-center g-4 row-cols-3">
						<div class="">
							<div class="card team-card h-100 shadow-sm p-4 ">
								<img src="images/portraitolivier.jpg" width="180px" height="180px" class="rounded-circle mx-auto mb-3 team-member-img object-fit-cover" alt="Photo de Olivier">
								<h5 class="mb-1">Olivier</h5>
								<p class="text-muted small mb-3">Directeur</p>

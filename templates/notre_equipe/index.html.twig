									</button>

									<a href="#" class="text-secondary mx-2 fs-4" aria-label="Profil LinkedIn Olivier">
										<i class="bi bi-linkedin"></i>
									</a>
									<a href="#" class="text-secondary mx-2 fs-4" aria-label="Profil Twitter Olivier">
										<i class="bi bi-twitter"></i>
									</a>
